{
  "services": {
    "gateway": {
      "name": "gateway",
      "image": "nginx:alpine",
      "ports": [
        "80:80",
        "443:443"
      ],
      "healthcheck": {
        "test": [
          "CMD",
          "wget",
          "-q",
          "-O",
          "/dev/null",
          "http://localhost/health"
        ],
        "interval": "30s",
        "timeout": "5s",
        "retries": 3
      },
      "depends_on": [
        "user-service",
        "order-service",
        "inventory-service"
      ],
      "environment": {},
      "environment_raw": {},
      "labels": {},
      "source_file": "examples/microservices/docker-compose.yml",
      "resolved_ports": [
        {
          "raw": "80:80",
          "host": "",
          "host_port": "80",
          "container_port": "80",
          "protocol": ""
        },
        {
          "raw": "443:443",
          "host": "",
          "host_port": "443",
          "container_port": "443",
          "protocol": ""
        }
      ],
      "env_resolved": {}
    },
    "user-service": {
      "name": "user-service",
      "image": "myapp/user-service:latest",
      "ports": [
        "8001:8000"
      ],
      "healthcheck": {
        "test": [
          "CMD",
          "python",
          "-c",
          "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health')"
        ],
        "interval": "30s",
        "timeout": "5s",
        "retries": 3,
        "start_period": "10s"
      },
      "depends_on": [
        "postgres",
        "redis"
      ],
      "environment": {
        "DATABASE_URL": "postgresql://app:@postgres:5432/users",
        "REDIS_URL": "redis://redis:6379/0"
      },
      "environment_raw": {
        "DATABASE_URL": "postgresql://app:${DB_PASSWORD}@postgres:5432/users",
        "REDIS_URL": "redis://redis:6379/0"
      },
      "labels": {},
      "source_file": "examples/microservices/docker-compose.yml",
      "resolved_ports": [
        {
          "raw": "8001:8000",
          "host": "",
          "host_port": "8001",
          "container_port": "8000",
          "protocol": ""
        }
      ],
      "env_resolved": {
        "DATABASE_URL": "postgresql://app:@postgres:5432/users",
        "REDIS_URL": "redis://redis:6379/0"
      }
    },
    "order-service": {
      "name": "order-service",
      "image": "myapp/order-service:latest",
      "ports": [
        "8002:8000"
      ],
      "healthcheck": {
        "test": [
          "CMD",
          "python",
          "-c",
          "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health')"
        ],
        "interval": "30s",
        "timeout": "5s",
        "retries": 3
      },
      "depends_on": [
        "postgres",
        "redis",
        "rabbitmq"
      ],
      "environment": {
        "DATABASE_URL": "postgresql://app:@postgres:5432/orders",
        "QUEUE_URL": "amqp://rabbitmq:5672"
      },
      "environment_raw": {
        "DATABASE_URL": "postgresql://app:${DB_PASSWORD}@postgres:5432/orders",
        "QUEUE_URL": "amqp://rabbitmq:5672"
      },
      "labels": {},
      "source_file": "examples/microservices/docker-compose.yml",
      "resolved_ports": [
        {
          "raw": "8002:8000",
          "host": "",
          "host_port": "8002",
          "container_port": "8000",
          "protocol": ""
        }
      ],
      "env_resolved": {
        "DATABASE_URL": "postgresql://app:@postgres:5432/orders",
        "QUEUE_URL": "amqp://rabbitmq:5672"
      }
    },
    "inventory-service": {
      "name": "inventory-service",
      "image": "myapp/inventory-service:latest",
      "ports": [
        "8003:8000"
      ],
      "healthcheck": {
        "test": [
          "CMD",
          "python",
          "-c",
          "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health')"
        ],
        "interval": "30s",
        "timeout": "5s",
        "retries": 3
      },
      "depends_on": [
        "postgres"
      ],
      "environment": {
        "DATABASE_URL": "postgresql://app:@postgres:5432/inventory"
      },
      "environment_raw": {
        "DATABASE_URL": "postgresql://app:${DB_PASSWORD}@postgres:5432/inventory"
      },
      "labels": {},
      "source_file": "examples/microservices/docker-compose.yml",
      "resolved_ports": [
        {
          "raw": "8003:8000",
          "host": "",
          "host_port": "8003",
          "container_port": "8000",
          "protocol": ""
        }
      ],
      "env_resolved": {
        "DATABASE_URL": "postgresql://app:@postgres:5432/inventory"
      }
    },
    "worker": {
      "name": "worker",
      "image": "myapp/worker:latest",
      "ports": [],
      "healthcheck": {
        "test": [
          "CMD",
          "python",
          "-c",
          "import sys; sys.exit(0)"
        ],
        "interval": "60s",
        "timeout": "10s",
        "retries": 3
      },
      "depends_on": [
        "postgres",
        "rabbitmq"
      ],
      "environment": {
        "DATABASE_URL": "postgresql://app:@postgres:5432/app",
        "QUEUE_URL": "amqp://rabbitmq:5672"
      },
      "environment_raw": {
        "DATABASE_URL": "postgresql://app:${DB_PASSWORD}@postgres:5432/app",
        "QUEUE_URL": "amqp://rabbitmq:5672"
      },
      "labels": {},
      "source_file": "examples/microservices/docker-compose.yml",
      "resolved_ports": [],
      "env_resolved": {
        "DATABASE_URL": "postgresql://app:@postgres:5432/app",
        "QUEUE_URL": "amqp://rabbitmq:5672"
      }
    },
    "postgres": {
      "name": "postgres",
      "image": "postgres:16-alpine",
      "ports": [
        "5432:5432"
      ],
      "healthcheck": {
        "test": [
          "CMD-SHELL",
          "pg_isready -U app"
        ],
        "interval": "10s",
        "timeout": "5s",
        "retries": 5
      },
      "depends_on": [],
      "environment": {
        "POSTGRES_DB": "app",
        "POSTGRES_USER": "app",
        "POSTGRES_PASSWORD": "change-me"
      },
      "environment_raw": {
        "POSTGRES_DB": "app",
        "POSTGRES_USER": "app",
        "POSTGRES_PASSWORD": "${DB_PASSWORD:-change-me}"
      },
      "labels": {},
      "source_file": "examples/microservices/docker-compose.yml",
      "resolved_ports": [
        {
          "raw": "5432:5432",
          "host": "",
          "host_port": "5432",
          "container_port": "5432",
          "protocol": ""
        }
      ],
      "env_resolved": {
        "POSTGRES_DB": "app",
        "POSTGRES_USER": "app",
        "POSTGRES_PASSWORD": "change-me"
      }
    },
    "redis": {
      "name": "redis",
      "image": "redis:7-alpine",
      "ports": [
        "6379:6379"
      ],
      "healthcheck": {
        "test": [
          "CMD",
          "redis-cli",
          "ping"
        ],
        "interval": "15s",
        "timeout": "5s",
        "retries": 3
      },
      "depends_on": [],
      "environment": {},
      "environment_raw": {},
      "labels": {},
      "source_file": "examples/microservices/docker-compose.yml",
      "resolved_ports": [
        {
          "raw": "6379:6379",
          "host": "",
          "host_port": "6379",
          "container_port": "6379",
          "protocol": ""
        }
      ],
      "env_resolved": {}
    },
    "rabbitmq": {
      "name": "rabbitmq",
      "image": "rabbitmq:3-management-alpine",
      "ports": [
        "5672:5672",
        "15672:15672"
      ],
      "healthcheck": {
        "test": [
          "CMD",
          "rabbitmq-diagnostics",
          "-q",
          "ping"
        ],
        "interval": "30s",
        "timeout": "10s",
        "retries": 5
      },
      "depends_on": [],
      "environment": {},
      "environment_raw": {},
      "labels": {},
      "source_file": "examples/microservices/docker-compose.yml",
      "resolved_ports": [
        {
          "raw": "5672:5672",
          "host": "",
          "host_port": "5672",
          "container_port": "5672",
          "protocol": ""
        },
        {
          "raw": "15672:15672",
          "host": "",
          "host_port": "15672",
          "container_port": "15672",
          "protocol": ""
        }
      ],
      "env_resolved": {}
    }
  },
  "endpoints": [],
  "anomalies": [],
  "cycles": [],
  "hubs": []
}